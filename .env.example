# 飞书开放平台: https://open.feishu.cn → 创建应用 → 凭证与基础信息
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书多维表格: 表格 URL 中 base_id 和 table_id
# 示例: https://xxx.feishu.cn/base/BITABLE_APP_TOKEN?table=TABLE_ID
BITABLE_APP_TOKEN=xxxxxxxxxxxxxxxxxxxx
BITABLE_TABLE_ID=tblxxxxxxxxxxxxxxxx

# B站 (无需配置，免费API)
# 抖音 - 蝉妈妈/飞瓜等第三方平台API Key（可选）
DOUYIN_API_KEY=
DOUYIN_API_SECRET=
